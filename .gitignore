# Obsidian workspace state (changes constantly, not meaningful to track)
.obsidian/workspace.json
.obsidian/workspace-mobile.json

# Obsidian installed plugins: third-party code + per-plugin data.json that can
# hold personal config (Obsidian Git remote URL, plugin tokens, local paths).
# The plugin list in community-plugins.json is enough to reinstall them.
.obsidian/plugins/

# Large binary files
_attachments/*.mp3
_attachments/*.mp4
_attachments/*.wav
_attachments/*.m4a
_attachments/*.pptx
_attachments/*.docx
_attachments/*.xlsx
_attachments/*.pdf
_attachments/*.zip

# Obsidian trash
.trash/

# Synology Drive sync metadata
.SynologyWorkingDirectory/

# Credentials (never commit your real .env; copy from _scripts/.env.example)
.env
_scripts/.env

# Secrets backstop: keep a stray key, cert, or credential file from ever being
# committed by accident (extension-scoped so it won't catch a note title)
*.pem
*.key
*.p12
*.pfx
*.jks
id_rsa*
id_ed25519*
secrets.y*ml
auth.json

# Local Claude settings (machine-specific)
.claude/settings.local.json

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Python bytecode cache (regenerable)
__pycache__/
*.pyc

# Runtime logs (live, machine-local)
_scripts/pull-emails.log

# Runtime DB files (regenerated by the pipeline; may contain REAL PII: real emails,
# phone numbers, subjects, speaker maps). Only entity-registry.json is tracked.
_db/*.json
!_db/entity-registry.json
_db/*.csv
_db/maintenance-todo.md
_db/backups/*
!_db/backups/.gitkeep

# Ingested/generated content (real meeting transcripts, emails, screenshots).
# This template ships empty; never commit real captured content.
00-Inbox/*
!00-Inbox/.gitkeep
!00-Inbox/_screenshots/
00-Inbox/_screenshots/*
!00-Inbox/_screenshots/.gitkeep
_attachments/*.txt
_attachments/*.json
_attachments/*.md
_attachments/screenshots/*
!_attachments/screenshots/.gitkeep

# Internal working notes: docs/ subfolders are local-only by default.
# Covers audit notes and brainstorming specs (docs/superpowers/), etc.
# Top-level docs files (e.g. docs/plugins.md) stay tracked.
# To publish a specific subfolder, add a negation like !docs/published/.
docs/*/
